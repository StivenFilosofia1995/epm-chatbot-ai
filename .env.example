# Copiar a .env y completar con credenciales reales. NUNCA commitear el .env real.

# ─── Supabase (obligatorio) ───────────────────────────────────────────────────
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=tu-service-role-key

# ─── Anthropic Claude (obligatorio) ───────────────────────────────────────────
# Sin esto el bot NO puede generar ninguna respuesta. Verificar en GET /health
# (integraciones.anthropic_configurado) si el bot deja de responder.
ANTHROPIC_API_KEY=tu-anthropic-api-key
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# ─── Servidor ──────────────────────────────────────────────────────────────
PORT=3000
CORS_ORIGIN=*
ADMIN_API_KEY=clave-secreta-para-scrape-manual-y-panel-admin
ADMIN_INTERNAL_PORT=8001

# ─── Fundación EPM ─────────────────────────────────────────────────────────
EPM_PROGRAMACION_URL=https://www.grupo-epm.com/site/fundacionepm/programacion/

# ─── Opcionales ────────────────────────────────────────────────────────────
# REDIS_URL=redis://...                  # cache de sesiones persistente (si no, usa memoria)
# ENABLE_SCHEDULER=false                 # cron diario/mensual de scraping automático
# ENABLE_SCRAPER=false                   # habilita /scrape y /reconcile
# ENABLE_AUTO_SCRAPING=false             # dispara scraping en background si falta programación
# HUMAN_TAKEOVER_TIMEOUT_MINUTES=30      # minutos antes de devolver el chat al bot
# JWT_SECRET=...                         # solo si valida JWT del panel admin en este servicio
